# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real secrets.

# ---- HuggingFace ----
# Get a token at https://huggingface.co/settings/tokens
# Needed to download gated models (Llama 3.1/3.2/Guard) and to publish your trained adapters.
HF_TOKEN=

# ---- Weights & Biases (optional, for training logs) ----
WANDB_API_KEY=

# ---- Search backends (Block 4) ----
# DuckDuckGo via `ddgs` needs no key; use SEARXNG_URL when running the Docker SearXNG service.
SEARXNG_URL=http://localhost:8080

# ---- Cache (Block 5) ----
REDIS_URL=redis://localhost:6379/0

# ---- Where adapters / datasets live (override in Colab to point at Drive) ----
XRAG_DATA_DIR=./data
XRAG_MODELS_DIR=./models
